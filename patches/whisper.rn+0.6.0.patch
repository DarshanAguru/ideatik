+JNIEnv *getEnv(bool *needsDetach = nullptr) {
+    if (needsDetach) {
+        *needsDetach = false;
+    }
+    if (!g_javaVm) {
+        return nullptr;
+    }
+
+    JNIEnv *env = nullptr;
+    jint status = g_javaVm->GetEnv(reinterpret_cast<void **>(&env), JNI_VERSION_1_6);
+    if (status == JNI_OK) {
+        return env;
+    }
+    if (status == JNI_EDETACHED) {
+        if (g_javaVm->AttachCurrentThread(&env, nullptr) == JNI_OK) {
+            if (needsDetach) {
+                *needsDetach = true;
+            }
+            return env;
+        }
+    }
+    return nullptr;
+}
