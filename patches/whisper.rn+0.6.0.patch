+std::string toStdString(JNIEnv *env, jstring value) {
+    if (!value) {
+        return {};
+    }
+    const char *chars = env->GetStringUTFChars(value, nullptr);
+    std::string stringValue = chars ? std::string(chars) : std::string();
+    if (chars) {
+        env->ReleaseStringUTFChars(value, chars);
+    }
+    return stringValue;
+}
