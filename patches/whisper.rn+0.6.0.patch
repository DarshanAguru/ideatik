+    ${RNWHISPER_LIB_DIR}/ggml-backend-meta.cpp
+    ${RNWHISPER_LIB_DIR}/ggml-backend-reg.cpp
+    ${RNWHISPER_LIB_DIR}/ggml-backend-dl.cpp
