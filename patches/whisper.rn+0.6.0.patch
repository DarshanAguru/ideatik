+std::vector<uint8_t> readFileBytes(const std::string &filePath) {
+    std::ifstream stream(filePath, std::ios::binary);
+    if (!stream) {
+        return {};
+    }
+    return std::vector<uint8_t>(
+        std::istreambuf_iterator<char>(stream),
+        std::istreambuf_iterator<char>());
+}
