# ─── Logs ────────────────────────────────────────────────────────────────────
logs/
*.log

# ─── Whisper model files (large binary — download via Settings) ──────────────
# These are downloaded at runtime via the in-app model downloader.
# Committed model files would bloat the repo unnecessarily.
src/models/
android/app/src/main/assets/models/
ios/models/
*.bin
*.ggml
